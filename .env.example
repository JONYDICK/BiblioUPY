# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/biblioupy

# Server Configuration
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# HTTPS Configuration (development only)
USE_HTTPS=false

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# AWS S3 Configuration
# Create IAM user in AWS console and replace with your credentials
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_bucket_name

# SMTP Configuration (optional, for email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Application Secrets (MUST be set in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=generate_a_random_secret_key_here_minimum_32_characters

# Redis (optional, for session store in production)
REDIS_URL=redis://localhost:6379

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
